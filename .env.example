# 应用运行环境：本地开发使用 dev，生产环境可改为 prod
app-env = dev
log-level = INFO

# DeepSeek 大语言模型：为八个 Agent 提供意图判断、需求理解、规划、选型、校验和报告生成
# url 必须是兼容 OpenAI 协议的服务地址
url = https://api.deepseek.com
api-key = <FILL_DEEPSEEK_API_KEY>
model = <FILL_DEEPSEEK_MODEL>
llm-timeout = 60

# SerpAPI：可选的实时硬件搜索和价格证据来源
# 仅当 live-search-enabled=true 时，推荐流程才会主动消耗搜索额度
serpapi-key = <FILL_SERPAPI_KEY>
live-search-enabled = false

# MySQL：预留给任务、Agent 轨迹、知识元数据和推荐结果持久化
# 当前运行时仓库仍为内存实现；请按本地数据库修改用户名、密码、地址和数据库名
mysql-url = mysql+pymysql://<USER>:<PASSWORD>@127.0.0.1:3306/<DATABASE>

# 本地 RAG：从硬件知识目录召回相关规格、价格和来源
rag-enabled = true
# 返回给选型 Agent 的知识条数
rag-top-k = 16
# 混合检索中的向量权重，剩余权重用于关键词匹配
rag-vector-weight = 0.8

# Voyage Embedding：将知识分片和用户查询转换为向量
# Voyage 不可用时，系统会自动退化为本地关键词检索
embedding-base-url = https://api.voyageai.com/v1
embedding-model = voyage-code-3
embedding-api-key = <FILL_VOYAGE_API_KEY>
embedding-dimension = 1024

# Redis：当前未进入运行链路，保留 disabled 即可
redis-url = disabled

# Qdrant：当前未进入运行链路；未来用于持久化向量和分片元数据
qdrant-url = disabled
qdrant-api-key =
qdrant-collection = diy_multiagents_knowledge
qdrant-distance = cosine
qdrant-timeout = 10

# 以下抓取平台仅供知识库采集和动态更新脚本按需使用，主服务启动时不要求全部填写
# crawler-provider 是预留的首选抓取平台标记
crawler-provider = apify

# Apify：运行网页抓取 Actor，适合厂商规格页和动态网页
# Token 获取地址：https://console.apify.com/account/integrations
apify-api-token = <FILL_APIFY_API_TOKEN>
apify-actor-id = apify~web-scraper

# Bright Data：用于需要代理、浏览器渲染或反爬处理的商品与价格采集
brightdata-api-token = <FILL_BRIGHTDATA_API_TOKEN>
brightdata-zone = <FILL_BRIGHTDATA_ZONE>

# Zyte：用于商品详情、列表和分页等结构化网页提取
zyte-api-key = <FILL_ZYTE_API_KEY>

# Firecrawl：将网页转换为适合 RAG 入库的 Markdown 或结构化 JSON
firecrawl-base-url = https://api.firecrawl.dev/v2
firecrawl-api-key = <FILL_FIRECRAWL_API_KEY>
